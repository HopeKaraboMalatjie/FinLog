<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_primary"
    android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/smart_insights_title" android:textSize="22sp" android:textStyle="bold"
        android:textColor="@color/text_primary" android:layout_marginBottom="8dp"/>

    <TextView android:id="@+id/tvComparison" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="vs last month: 0% less spending" android:textColor="@color/text_muted"
        android:textSize="14sp" android:layout_marginBottom="16dp"/>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvInsights"
        android:layout_width="match_parent" android:layout_height="match_parent"/>

</LinearLayout>
