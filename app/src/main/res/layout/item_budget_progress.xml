<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#1C1F27"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCategoryName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Food 🍔"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_status"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="ON TRACK"
                android:textColor="#FFFFFF"
                android:textSize="10sp"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressSpending"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:max="100"
            android:progress="60"
            android:progressTint="#22C55E"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSpentAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Spent: R 450"
                android:textColor="#9CA3AF"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvLimitAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max: R 800"
                android:textColor="#EF4444"
                android:textSize="12sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvMinGoalHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Min target: R 200"
            android:textColor="#22C55E"
            android:textSize="11sp"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
