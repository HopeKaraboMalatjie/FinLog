<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="80dp"
    android:layout_margin="2dp" app:cardCornerRadius="8dp"
    app:cardElevation="0dp" android:id="@+id/cardDay">

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center" android:padding="4dp">

        <TextView android:id="@+id/tvDay"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="@color/text_primary"/>

        <TextView android:id="@+id/tvAmount"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="" android:textSize="10sp" android:textColor="@color/text_muted"
            android:layout_marginTop="2dp" android:gravity="center"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
