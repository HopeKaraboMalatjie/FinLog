<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FinLog" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/green_accent</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/expense_red</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
    <style name="Theme.FinLog.Splash" parent="Theme.FinLog">
        <item name="android:windowBackground">@color/green_dark</item>
        <item name="android:statusBarColor">@color/green_dark</item>
    </style>
    <style name="FinLog.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_secondary</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="hintTextColor">@color/text_muted</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>

    <style name="CalendarDayHeader">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.FinLog.Headline" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.FinLog.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    <style name="TextAppearance.FinLog.Amount.Income" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/income_green</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.FinLog.Amount.Expense" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/expense_red</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
